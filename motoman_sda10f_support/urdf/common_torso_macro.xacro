<?xml version="1.0" ?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:macro name="torso" params="name prefix left_base_prefix right_base_prefix">
    <!-- link list -->
    <link name="${prefix}torso_base_link">
      <visual>
        <geometry>
          <mesh filename="package://motoman_sda10f_support/meshes/torso/visual/base_link.stl" />
        </geometry>
        <xacro:material_yaskawa_blue/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://motoman_sda10f_support/meshes/torso/collision/base_link.stl" />
        </geometry>
      </collision>
    </link>
    <link name="${prefix}${left_base_prefix}base_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://motoman_sda10f_support/meshes/torso/visual/link_1.stl"/>
        </geometry>
        <xacro:material_yaskawa_white/>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://motoman_sda10f_support/meshes/torso/collision/link_1.stl" />
        </geometry>
      </collision>
    </link>
    <link name="${prefix}${right_base_prefix}base_link"/>
    <link name="${prefix}${left_base_prefix}base"/>
    <link name="${prefix}${right_base_prefix}base"/>

    <!-- joint list -->
    <joint name="${prefix}${left_base_prefix}joint_1" type="revolute">
      <parent link="${prefix}torso_base_link"/>
      <child link="${prefix}${left_base_prefix}base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1" />
      <limit lower="${radians(-170)}" upper="${radians(170)}" effort="100" velocity="${radians(130)}" />
    </joint>
    <joint name="${prefix}${right_base_prefix}joint_1" type="revolute">
      <parent link="${prefix}torso_base_link"/>
      <child link="${prefix}${right_base_prefix}base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1" />
      <limit lower="${radians(-170)}" upper="${radians(170)}" effort="100" velocity="${radians(130)}" />
      <mimic joint="${prefix}${left_base_prefix}joint_1" multiplier="1" offset="0"/>
    </joint>
    <joint name="${prefix}${left_base_prefix}base_link-${prefix}${left_base_prefix}base" type="fixed">
      <parent link="${prefix}${left_base_prefix}base_link"/>
      <child link="${prefix}${left_base_prefix}base"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    <joint name="${prefix}${right_base_prefix}base_link-${prefix}${right_base_prefix}base" type="fixed">
      <parent link="${prefix}${right_base_prefix}base_link"/>
      <child link="${prefix}${right_base_prefix}base"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    <!-- end of joint list -->
  </xacro:macro>
</robot>
